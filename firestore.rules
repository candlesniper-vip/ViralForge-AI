rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // USERS
    function isValidUserCreate(data) {
      return data.keys().hasAll(['email', 'createdAt', 'updatedAt']) &&
             data.email is string && data.email.size() <= 254 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserCreate(incoming());
      allow update: if isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'currentTeamId', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
    }

    match /users/{userId}/connections/{connectionId} {
      allow read, list: if isOwner(userId);
      allow set, create, update, delete: if isOwner(userId) && isValidId(connectionId);
    }

    match /users/{userId}/notifications/{notificationId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(notificationId);
      allow update: if isOwner(userId) && isValidId(notificationId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
    }

    function isTeamMember(teamId) {
      // Cost efficient way for specific resources.
      return isSignedIn() && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    // TEAMS
    function isValidTeamCreate(data) {
      return data.keys().hasAll(['name', 'ownerId', 'plan', 'createdAt', 'updatedAt']) &&
             data.ownerId == request.auth.uid &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    match /teams/{teamId} {
      allow read: if isSignedIn() && (existing().ownerId == request.auth.uid || isTeamMember(teamId));
      allow create: if isSignedIn() && isValidId(teamId) && isValidTeamCreate(incoming());
      allow update: if isSignedIn() && existing().ownerId == request.auth.uid &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'plan', 'stripeCustomerId', 'stripeSubscriptionId', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
    }

    match /teams/{teamId}/members/{memberId} {
      allow read: if isSignedIn() && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid || request.auth.uid == memberId);
      allow list: if isSignedIn() && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid || isTeamMember(teamId));
      allow create: if isSignedIn() && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid &&
                    incoming().keys().hasAll(['userId', 'role', 'joinedAt']) &&
                    incoming().joinedAt == request.time;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid;
    }

    // POSTS
    function isValidPostCreate(data) {
      return data.keys().hasAll(['content', 'status', 'authorId', 'createdAt', 'updatedAt']) &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    match /teams/{teamId}/posts/{postId} {
      allow read: if isTeamMember(teamId);
      allow list: if isTeamMember(teamId);
      allow create: if isTeamMember(teamId) && isValidId(postId) && isValidPostCreate(incoming());
      allow update: if isTeamMember(teamId) && isValidId(postId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['content', 'platforms', 'status', 'scheduledAt', 'mediaUrls', 'aiScore', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
      allow delete: if isTeamMember(teamId) && isValidId(postId);
    }
  }
}
